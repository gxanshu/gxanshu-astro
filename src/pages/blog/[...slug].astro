---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Breadcrumbs from '@/components/ui/Breadcrumbs.astro';
import SectionHead from '@/components/ui/SectionHead.astro';
import ReadingProgress from '@/components/ui/ReadingProgress.astro';
import { formatDateDot } from '@/lib/utils';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const entries = await getCollection('blogs');
  return entries.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content, remarkPluginFrontmatter } = await render(entry);

const allBlogs = (await getCollection('blogs'))
  .filter((b) => b.id !== entry.id)
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 2);
---

<BaseLayout seo={entry.data.seo}>
  <Fragment slot="before-main">
    <ReadingProgress target="article.post" />
  </Fragment>

  <Breadcrumbs
    items={[
      { label: '~', href: '/' },
      { label: 'blog', href: '/blog' },
      { label: entry.id },
    ]}
  />

  <article class="post">
    <header class="post-head">
      <div class="post-meta mono-label">
        <span>{formatDateDot(entry.data.date)}</span>
        {entry.data.tags?.[0] && (
          <>
            <span>·</span>
            <span>{entry.data.tags[0]}</span>
          </>
        )}
        <span>·</span>
        <span>{remarkPluginFrontmatter.minutesRead}</span>
      </div>
      <h1>{entry.data.title}</h1>
      <p class="lede">{entry.data.seo.description}</p>
    </header>
    <div class="post-body">
      <Content />
    </div>
  </article>

  {allBlogs.length > 0 && (
    <section class="section">
      <SectionHead title="Keep reading" link={{ href: '/blog', label: 'All posts →' }} />
      <div class="grid-2" style="margin-top:20px">
        {allBlogs.map((p, i) => (
          <a class="proj" href={`/blog/${p.id}/`}>
            <div class:list={['proj-thumb', i % 2 === 0 ? 'dither' : 'dither-amber']}></div>
            <div>
              <div class="proj-meta mono-label">
                {p.data.tags?.[0] ?? 'Writing'} · {new Date(p.data.date).getUTCFullYear()}
              </div>
              <div class="proj-title">{p.data.title}</div>
              <div class="proj-desc">{p.data.seo.description}</div>
            </div>
          </a>
        ))}
      </div>
    </section>
  )}
</BaseLayout>

<style>
  .post { max-width: 740px; margin: 0 auto; }
  .post-head { margin-bottom: 28px; }
  .post-meta {
    display: flex;
    gap: 10px;
    font-size: 11px;
    color: var(--ink-3);
    margin-bottom: 12px;
    flex-wrap: wrap;
  }
  .post h1 {
    font-size: 36px;
    line-height: 1.1;
    margin-bottom: 18px;
    letter-spacing: -0.02em;
  }
  .lede {
    font-family: var(--font-serif), 'IBM Plex Serif', Georgia, serif;
    font-size: 18px;
    line-height: 1.55;
    font-style: italic;
    color: var(--ink-2);
    padding-left: 16px;
    border-left: 3px solid var(--amber);
    margin: 0;
  }
  @media (max-width: 680px) {
    .post h1 { font-size: 28px; }
    .lede { font-size: 16px; }
  }
</style>
