---
import { getCollection, getEntry } from 'astro:content';
import Container from '@/components/Container.astro';
import BaseLayout from '@/layouts/BaseLayout.astro';
import NotePreview from '@/components/ui/NotePreview.astro';

const entry = await getEntry('pages', 'notes');
const notes = (await getCollection('notes')).sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
---

<BaseLayout seo={entry.data.seo}>
  <Container as='section' class='pt-16 pb-12'>
    <div class="flex flex-col gap-2">
      <h1 class="text-xl font-semibold text-headings tracking-tight">Notes</h1>
      <p class="text-foreground">Quick thoughts and observations.</p>
    </div>
  </Container>
  <Container as='section' class='pb-12'>
    <ul class="flex flex-col">
      {notes.map((post, i) => <NotePreview entry={post} index={i} />)}
    </ul>
  </Container>
</BaseLayout>
