---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Breadcrumbs from '@/components/ui/Breadcrumbs.astro';
import { formatDateDot } from '@/lib/utils';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const entries = await getCollection('notes');
  return entries.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content, remarkPluginFrontmatter } = await render(entry);
---

<BaseLayout seo={entry.data.seo}>
  <Breadcrumbs
    items={[
      { label: '~', href: '/' },
      { label: 'notes', href: '/notes' },
      { label: entry.id },
    ]}
  />

  <article class="post">
    <header class="post-head">
      <div class="post-meta mono-label">
        <span>{formatDateDot(entry.data.date)}</span>
        <span>·</span>
        <span>{remarkPluginFrontmatter.minutesRead}</span>
      </div>
      <h1>{entry.data.title}</h1>
      {entry.data.seo.description && (
        <p class="lede">{entry.data.seo.description}</p>
      )}
    </header>
    <div class="post-body">
      <Content />
    </div>
  </article>
</BaseLayout>

<style>
  .post { max-width: 740px; margin: 0 auto; }
  .post-head { margin-bottom: 28px; }
  .post-meta {
    display: flex;
    gap: 10px;
    font-size: 11px;
    color: var(--ink-3);
    margin-bottom: 12px;
  }
  .post h1 {
    font-size: 36px;
    line-height: 1.1;
    margin-bottom: 18px;
    letter-spacing: -0.02em;
  }
  .lede {
    font-family: var(--font-serif), 'IBM Plex Serif', Georgia, serif;
    font-size: 18px;
    line-height: 1.55;
    font-style: italic;
    color: var(--ink-2);
    padding-left: 16px;
    border-left: 3px solid var(--amber);
    margin: 0;
  }
  @media (max-width: 680px) {
    .post h1 { font-size: 28px; }
    .lede { font-size: 16px; }
  }
</style>
