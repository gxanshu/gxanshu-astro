---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Breadcrumbs from '@/components/ui/Breadcrumbs.astro';
import SectionHead from '@/components/ui/SectionHead.astro';
import { formatDate } from '@/lib/utils';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const entries = await getCollection('projects');
  return entries.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content, remarkPluginFrontmatter } = await render(entry);

const related = (await getCollection('projects'))
  .filter((p) => p.id !== entry.id)
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 2);

const year = new Date(entry.data.date).getUTCFullYear();
---

<BaseLayout seo={entry.data.seo}>
  <Breadcrumbs
    items={[
      { label: '~', href: '/' },
      { label: 'projects', href: '/projects' },
      { label: entry.id },
    ]}
  />

  <section class="proj-header">
    <div class="proj-header-left">
      <div class="mono-label">
        {entry.data.language ?? 'Project'} · {year}
      </div>
      <h1>{entry.data.title}</h1>
      <p class="proj-lede">{entry.data.tagline ?? entry.data.seo.description}</p>
      <div class="proj-actions">
        <a class="btn primary" href={`https://github.com/gxanshu/${entry.id}`} target="_blank" rel="noopener noreferrer">
          <span>◆</span> View on GitHub
        </a>
      </div>
    </div>
    <aside class="proj-facts">
      <dl>
        <dt class="mono-label">Status</dt>
        <dd><span class="pill pill-live">● live</span></dd>
        <dt class="mono-label">Year</dt>
        <dd class="mono">{year}</dd>
        {entry.data.language && (
          <>
            <dt class="mono-label">Language</dt>
            <dd class="mono">{entry.data.language}</dd>
          </>
        )}
        <dt class="mono-label">License</dt>
        <dd class="mono">MIT</dd>
        <dt class="mono-label">Read</dt>
        <dd class="mono">{remarkPluginFrontmatter.minutesRead}</dd>
        <dt class="mono-label">Updated</dt>
        <dd class="mono">{formatDate(entry.data.date)}</dd>
      </dl>
    </aside>
  </section>

  <section class="section">
    <SectionHead title="About" />
    <div class="two-col">
      <div class="about-body post-body">
        <Content />
      </div>
      <aside class="side-panel box">
        <div class="side-head mono-label">&gt; side_panel</div>
        <div class="side-row">
          <span class="mono-label">Maintained by</span>
          <span>Anshu Meena</span>
        </div>
        {entry.data.language && (
          <div class="side-row">
            <span class="mono-label">Primary</span>
            <span>{entry.data.language}</span>
          </div>
        )}
        <div class="side-row">
          <span class="mono-label">License</span>
          <span>MIT</span>
        </div>
        <hr class="hr-pixel" style="margin:12px 0" />
        <div class="side-row">
          <span class="mono-label">Published</span>
          <span>{formatDate(entry.data.date)}</span>
        </div>
      </aside>
    </div>
  </section>

  {related.length > 0 && (
    <section class="section">
      <SectionHead title="Related" link={{ href: '/projects', label: 'All projects →' }} />
      <div class="grid-2" style="margin-top:20px">
        {related.map((p, i) => (
          <a class="proj" href={`/projects/${p.id}/`}>
            <div class:list={['proj-thumb', i % 2 === 0 ? 'dither-amber' : 'dither']}></div>
            <div>
              <div class="proj-meta mono-label">
                {p.data.language ?? 'Project'} · {new Date(p.data.date).getUTCFullYear()}
              </div>
              <div class="proj-title">{p.data.title}</div>
              <div class="proj-desc">{p.data.tagline ?? p.data.seo.description}</div>
            </div>
          </a>
        ))}
      </div>
    </section>
  )}
</BaseLayout>

<style>
  .proj-header {
    display: grid;
    grid-template-columns: 1fr 260px;
    gap: 28px;
    align-items: start;
    margin-bottom: 32px;
  }
  .proj-header h1 {
    font-size: 36px;
    line-height: 1.1;
    margin: 10px 0 14px;
    letter-spacing: -0.02em;
  }
  .proj-lede {
    font-size: 15px;
    line-height: 1.6;
    color: var(--ink-2);
    max-width: 580px;
    margin-bottom: 20px;
  }
  .proj-actions {
    display: flex;
    gap: 10px;
    flex-wrap: wrap;
  }
  .proj-facts {
    border: 1.5px solid var(--ink);
    box-shadow: 4px 4px 0 var(--ink);
    background: var(--paper);
    padding: 16px 18px;
  }
  .proj-facts dl {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 10px 12px;
    margin: 0;
  }
  .proj-facts dt { margin-bottom: 2px; }
  .proj-facts dd { margin: 0; font-size: 13px; font-family: var(--font-mono), 'IBM Plex Mono', monospace; }
  .pill {
    font-family: var(--font-mono), 'IBM Plex Mono', monospace;
    font-size: 11px;
    padding: 2px 8px;
    border: 1px solid var(--rule);
    background: var(--paper-2);
  }
  .pill-live {
    color: var(--amber);
    border-color: var(--amber);
    background: var(--amber-bg);
  }
  .two-col {
    display: grid;
    grid-template-columns: 1fr 280px;
    gap: 28px;
    margin-top: 16px;
  }
  .about-body { font-size: 15px; line-height: 1.65; color: var(--ink-2); margin-top: 0; }
  .side-panel { padding: 16px 18px; }
  .side-head { margin-bottom: 12px; }
  .side-row {
    display: grid;
    grid-template-columns: 110px 1fr;
    gap: 10px;
    margin-bottom: 8px;
    font-size: 12px;
    font-family: var(--font-mono), 'IBM Plex Mono', monospace;
  }

  @media (max-width: 720px) {
    .proj-header { grid-template-columns: 1fr; }
    .proj-header h1 { font-size: 32px; }
    .two-col { grid-template-columns: 1fr; }
  }
</style>
