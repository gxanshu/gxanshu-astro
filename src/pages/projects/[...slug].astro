---
import Container from '@/components/Container.astro';
import BaseLayout from '@/layouts/BaseLayout.astro';
import { formatDate } from '@/lib/utils';
import { Image } from 'astro:assets';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const entries = await getCollection('projects');
  return entries.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content, remarkPluginFrontmatter } = await render(entry);
---

<BaseLayout seo={entry.data.seo}>
  <Container as='article' class='pt-16 pb-12'>
    <div class="flex flex-col gap-8">
      <header class="flex flex-col gap-4">
        <a href="/projects" class="text-sm text-muted-foreground hover:text-accent transition-colors duration-300">&larr; Back to projects</a>
        <div class="flex items-center gap-4">
          {entry.data.image && (
            <Image
              src={entry.data.image}
              alt={entry.data.title}
              height={56}
              width={56}
              class="rounded-xl border border-border/60"
              loading="eager"
            />
          )}
          <div class="flex flex-col gap-1">
            <h1 class="text-2xl font-bold text-headings tracking-tight">{entry.data.title}</h1>
            <div class="flex items-center gap-3 text-sm text-muted-foreground">
              <time>{formatDate(entry.data.date)}</time>
              <span class="w-1 h-1 rounded-full bg-border"></span>
              <span>{remarkPluginFrontmatter.minutesRead}</span>
            </div>
          </div>
        </div>
      </header>
      <div class="prose prose-lg dark:prose-invert prose-p:leading-relaxed max-w-none">
        <Content />
      </div>
    </div>
  </Container>
</BaseLayout>
