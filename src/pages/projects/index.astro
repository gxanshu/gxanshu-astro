---
import { getCollection, getEntry } from 'astro:content';
import Container from '@/components/Container.astro';
import BaseLayout from '@/layouts/BaseLayout.astro';
import ProjectPreview from '@/components/ui/ProjectPreview.astro';

const entry = await getEntry('pages', 'projects');
const projects = (await getCollection('projects')).sort((a, b) => a.data.date.getTime() - b.data.date.getTime());
---

<BaseLayout seo={entry.data.seo}>
  <Container as='section' class='pt-16 pb-12'>
    <div class="flex flex-col gap-2">
      <h1 class="text-xl font-semibold text-headings tracking-tight">Projects</h1>
      <p class="text-foreground">Things I've built and contributed to.</p>
    </div>
  </Container>
  <Container as='section' class='pb-12'>
    <ul class="flex flex-col">
      {projects.map((post, i) => <ProjectPreview entry={post} index={i} />)}
    </ul>
  </Container>
</BaseLayout>
