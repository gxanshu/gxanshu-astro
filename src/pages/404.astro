---
import { getEntry } from 'astro:content';
import BaseLayout from '@/layouts/BaseLayout.astro';
import Window from '@/components/ui/Window.astro';

const entry = await getEntry('pages', '404');
---

<BaseLayout seo={entry?.data.seo}>
  <div class="err-wrap">
    <Window title="ERR :: file_not_found.404" trailing="✕">
      <div class="err-body">
        <div class="mono-label">&gt; fs.stat</div>
        <h1>404 · file not found</h1>
        <p class="err-sub">
          {entry?.data.description ?? "The page you were looking for doesn't exist — or was moved, or never was."}
        </p>
        <pre class="err-trace">$ ls /var/www/gxanshu.in{Astro.url.pathname}
  ls: cannot access '{Astro.url.pathname}': No such file or directory
$ exit 1</pre>
        <div class="err-actions">
          <a class="btn primary" href="/"><span>←</span> Go home</a>
          <a class="btn" href="/blog"><span>✎</span> Read blog</a>
        </div>
      </div>
    </Window>
  </div>
</BaseLayout>

<style>
  .err-wrap {
    max-width: 620px;
    margin: 40px auto 0;
  }
  .err-body { padding: 0; }
  .err-body h1 {
    font-size: 32px;
    margin: 8px 0 12px;
    letter-spacing: -0.02em;
  }
  .err-sub {
    color: var(--ink-2);
    font-size: 15px;
    margin-bottom: 18px;
  }
  .err-trace {
    background: #1A1510;
    color: #C9B88F;
    padding: 14px 18px;
    font-family: var(--font-mono), 'IBM Plex Mono', monospace;
    font-size: 12px;
    line-height: 1.6;
    margin: 0 0 20px;
    border: 1.5px solid var(--ink);
    box-shadow: 3px 3px 0 var(--ink);
    overflow-x: auto;
    white-space: pre;
  }
  .err-actions {
    display: flex;
    gap: 10px;
    flex-wrap: wrap;
  }
</style>
