---
import { getEntry } from 'astro:content';
import BaseLayout from '@/layouts/BaseLayout.astro';
import Container from '@/components/Container.astro';

const entry = await getEntry('pages', '404');
---

<BaseLayout seo={entry?.data.seo}>
  <Container
    as="section"
    class="min-h-[calc(100vh-12rem)] flex items-center justify-center"
  >
    <div class="text-center space-y-6">
      <div class="text-8xl font-bold text-headings/10 select-none">404</div>
      <div class="space-y-2">
        <h1 class="text-2xl font-semibold text-headings">{entry?.data.title}</h1>
        <p class="text-foreground max-w-sm mx-auto">{entry?.data.description}</p>
      </div>
      <div class="flex gap-3 justify-center pt-4">
        <a
          href="/"
          class="inline-flex items-center gap-2 px-5 py-2.5 text-sm font-medium text-background bg-headings rounded-full hover:opacity-90 transition-opacity"
        >
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" /></svg>
          Go Home
        </a>
        <a
          href="/blog"
          class="inline-flex items-center gap-2 px-5 py-2.5 text-sm font-medium text-headings border border-border rounded-full hover:border-accent/40 hover:text-accent transition-all duration-300"
        >
          Read Blog
        </a>
      </div>
    </div>
  </Container>
</BaseLayout>
