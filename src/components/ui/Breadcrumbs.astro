---
interface Crumb {
  label: string;
  href?: string;
}

interface Props {
  items: Crumb[];
}

const { items } = Astro.props;
---

<div class="crumbs mono-label">
  {items.map((item, i) => (
    <>
      {item.href ? (
        <a href={item.href}>{item.label}</a>
      ) : (
        <span>{item.label}</span>
      )}
      {i < items.length - 1 && <span> / </span>}
    </>
  ))}
</div>
