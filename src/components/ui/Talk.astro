---
import { render, type CollectionEntry } from 'astro:content';

interface Props {
  entry: CollectionEntry<'talks'>;
}

const { entry } = Astro.props;
const { Content } = await render(entry);
---

<div class="box speaking">
  <div class="speak-meta mono-label">{entry.data.year} · {entry.data.location}</div>
  <div class="speak-title">
    {entry.data.url ? (
      <a href={entry.data.url} target="_blank" rel="noopener noreferrer">{entry.data.title}</a>
    ) : entry.data.title}
  </div>
  <div class="speak-venue">{entry.data.event}</div>
  <div class="speak-content small muted">
    <Content />
  </div>
</div>

<style>
  .speaking { padding: 18px 20px; margin-top: 20px; }
  .speak-meta { margin-bottom: 6px; }
  .speak-title {
    font-family: var(--font-mono), 'IBM Plex Mono', monospace;
    font-weight: 600;
    font-size: 17px;
    margin-bottom: 4px;
  }
  .speak-title a { text-decoration: none; }
  .speak-venue {
    font-size: 13px;
    color: var(--ink-2);
    margin-bottom: 8px;
  }
  .speak-content :global(p) { margin: 0; }
</style>
