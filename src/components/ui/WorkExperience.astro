---
import { render, type CollectionEntry } from 'astro:content';

interface Props {
  entry: CollectionEntry<'jobs'>;
}

const { entry } = Astro.props;
const { Content } = await render(entry);
---

<li class="group relative pl-6 before:absolute before:left-0 before:top-2.5 before:w-1.5 before:h-1.5 before:rounded-full before:bg-border group-hover:before:bg-accent before:transition-colors before:duration-300">
  <div class="flex flex-col gap-2">
    <div class="flex flex-col sm:flex-row sm:items-baseline sm:justify-between gap-1">
      <div class="flex flex-col">
        <span class="text-headings font-medium">{entry.data.title}</span>
        <span class="text-foreground">{entry.data.company} <span class="text-muted-foreground">/ {entry.data.location}</span></span>
      </div>
      <span class="text-muted-foreground text-sm shrink-0 tabular-nums">{entry.data.from} — {entry.data.to}</span>
    </div>
    <div class="prose dark:prose-invert max-w-none">
      <Content />
    </div>
  </div>
</li>
