---
import { Image } from 'astro:assets';
import { getImage } from 'astro:assets';
import { DEFAULT_CONFIGURATION } from '@/lib/constants';

interface Props {
  size?: number;
  class?: string;
}

const { size = 96, class: className } = Astro.props;

const image = await getImage({
  src: DEFAULT_CONFIGURATION.author.avatar,
  format: 'avif',
  width: size * 2,
  height: size * 2,
});
---

<div
  class:list={['relative shrink-0', className]}
  style={`width:${size}px;height:${size}px;border:1.5px solid var(--ink);box-shadow:3px 3px 0 var(--ink);background:var(--paper);overflow:hidden`}
>
  <Image
    loading="eager"
    src={image.src}
    alt={DEFAULT_CONFIGURATION.author.name}
    width={size}
    height={size}
    class="block object-cover w-full h-full"
  />
</div>
