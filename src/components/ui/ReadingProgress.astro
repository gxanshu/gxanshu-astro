---
interface Props {
  target?: string;
}
const { target = 'article.post' } = Astro.props;
---

<div class="progress">
  <div class="progress-bar" id="progress-bar"></div>
</div>

<script is:inline define:vars={{ target }}>
  (function () {
    function setup() {
      const bar = document.getElementById('progress-bar');
      const art = document.querySelector(target);
      if (!bar || !art) return;
      function up() {
        const r = art.getBoundingClientRect();
        const total = art.offsetHeight - window.innerHeight + 200;
        const val = total > 0 ? ((-r.top + 100) / total) * 100 : 0;
        bar.style.width = Math.min(100, Math.max(0, val)) + '%';
      }
      window.addEventListener('scroll', up, { passive: true });
      up();
    }
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', setup);
    } else {
      setup();
    }
    document.addEventListener('astro:page-load', setup);
  })();
</script>
