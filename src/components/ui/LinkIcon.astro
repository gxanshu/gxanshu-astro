---
interface Props {
  label: string;
}

const { label } = Astro.props;
const key = label.toLowerCase();

const glyphMap: Record<string, string> = {
  email: '@',
  github: '◆',
  telegram: '✈',
  x: '×',
  twitter: '×',
  linkedin: 'in',
  rss: '≫',
};

const glyph = glyphMap[key] ?? '◇';
---

<span class="c-ico">{glyph}</span>

<style>
  .c-ico {
    display: inline-block;
    width: 22px;
    height: 22px;
    line-height: 22px;
    text-align: center;
    background: var(--ink);
    color: var(--paper);
    font-family: var(--font-mono), 'IBM Plex Mono', monospace;
    font-size: 12px;
  }
</style>
