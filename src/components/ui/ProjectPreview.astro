---
import type { CollectionEntry } from 'astro:content';
import { formatDateYearMonth } from '@/lib/utils';
import ListRow from '@/components/ui/ListRow.astro';

interface Props {
  entry: CollectionEntry<'projects'>;
  showTag?: boolean;
}

const { entry, showTag = false } = Astro.props;
const lang = entry.data.language;
const langSlug = lang?.toLowerCase();
---

<li data-lang={langSlug ?? 'other'}>
  <ListRow
    href={`/projects/${entry.id}/`}
    date={formatDateYearMonth(entry.data.date)}
    title={entry.data.title}
    tag={showTag ? lang : undefined}
  />
</li>
