---
import type { CollectionEntry } from 'astro:content';
import { formatDate } from '@/lib/utils';
import { render } from 'astro:content';
interface Props {
  entry: CollectionEntry<'notes'>;
  index?: number;
}

const { entry, index = 0 } = Astro.props;
const { remarkPluginFrontmatter } = await render(entry);
---

<li class="animate-fade-up" style={`animation-delay: ${index * 60}ms`}>
  <a href={`/notes/${entry.id}/`} class="group flex items-baseline justify-between gap-4 py-3 -mx-3 px-3 rounded-lg hover:bg-surface/60 transition-all duration-300">
    <div class="flex flex-col gap-1 min-w-0">
      <span class="text-headings font-medium group-hover:text-accent transition-colors duration-300 truncate">{entry.data.title}</span>
      <span class="text-muted-foreground text-sm">{remarkPluginFrontmatter.minutesRead}</span>
    </div>
    <span class="text-muted-foreground text-sm shrink-0 tabular-nums">{formatDate(entry.data.date)}</span>
  </a>
</li>
