---
interface Props {
  title?: string;
  trailing?: string;
  class?: string;
  bodyClass?: string;
  noBody?: boolean;
}

const { title, trailing, class: className, bodyClass, noBody = false } = Astro.props;
---

<div class:list={['window', className]}>
  {title && (
    <div class="window-title">
      <span class="dots"><i></i><i></i><i></i></span>
      <span>{title}</span>
      {trailing && <span style="margin-left:auto;opacity:.7">{trailing}</span>}
    </div>
  )}
  {noBody ? (
    <slot />
  ) : (
    <div class:list={['window-body', bodyClass]}>
      <slot />
    </div>
  )}
</div>
