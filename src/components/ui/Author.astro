---
import { Image } from 'astro:assets';
import { getImage } from 'astro:assets';
import type { AuthorInfo } from '@/lib/constants';

interface Props extends AuthorInfo {}
const { avatar, name, headline, username, location } = Astro.props;

const image = await getImage({ src: avatar, format: 'avif'});
---

<div class="flex flex-col gap-6">
  <div class="flex items-center gap-4">
    <div class="relative shrink-0">
      <Image
        loading="eager"
        src={image.src}
        alt={name}
        width={56}
        height={56}
        class="rounded-full ring-2 ring-border/60 ring-offset-2 ring-offset-background"
      />
      <span class="absolute -bottom-0.5 -right-0.5 w-3.5 h-3.5 bg-emerald-500 rounded-full border-2 border-background animate-pulse-dot" title="Available for work"></span>
    </div>
    <div class="flex flex-col gap-0.5">
      <h1 class="text-xl font-semibold text-headings tracking-tight">{name}</h1>
      <p class="text-base text-foreground">{headline} <span class="text-muted-foreground">/ {location}</span></p>
    </div>
  </div>
</div>
