---
import type { CollectionEntry } from 'astro:content';
import { formatDateDot } from '@/lib/utils';
import { render } from 'astro:content';
import ListRow from '@/components/ui/ListRow.astro';

interface Props {
  entry: CollectionEntry<'blogs'>;
  showTag?: boolean;
}

const { entry, showTag = false } = Astro.props;
const { remarkPluginFrontmatter } = await render(entry);
const tag = entry.data.tags?.[0];
const tagSlug = tag?.toLowerCase();
---

<li data-tag={tagSlug ?? 'untagged'}>
  <ListRow
    href={`/blog/${entry.id}/`}
    date={formatDateDot(entry.data.date)}
    title={entry.data.title}
    read={remarkPluginFrontmatter.minutesRead}
    tag={showTag ? tag : undefined}
  />
</li>
